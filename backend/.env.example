# Copy to .env and edit. All values optional in development.
# NEVER put real secrets in this file — it is committed to git.
DATABASE_URL=sqlite:///./leads.db
ADMIN_API_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173
# Optional email notification for new leads (leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=
# Optional AI chat assistant (leave blank to disable the /api/chat endpoint)
ANTHROPIC_API_KEY=
# Model for the chat assistant. Default keeps the public endpoint cheap/fast;
# set to claude-opus-4-8 for richer replies at higher cost.
CHAT_MODEL=claude-haiku-4-5
